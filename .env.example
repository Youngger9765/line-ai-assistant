# === Vercel 部署用（vercel env add 設定） ===
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
SYNC_SECRET=any_random_string_you_choose

# === 本機 sync 用（sync script 讀這個檔） ===
BOT_URL=your-project.vercel.app
LINE_USER_ID=your_line_user_id_here

# === Vercel 自動設定（安裝 Upstash Redis integration 後產生） ===
# UPSTASH_REDIS_REST_URL=auto
# UPSTASH_REDIS_REST_TOKEN=auto
#
# 2024 年以前建立並遷移的 Vercel KV 也支援：
# KV_REST_API_URL=auto
# KV_REST_API_TOKEN=auto
